        "dim_target",
        "hkg_br_segment_target"
      ],
      "api_endpoints": [
        "GET /data/core/ups/audiences",
        "GET /data/foundation/flowservice/flows"
      ],
      "api_params": [
        "limit",
        "property"
      ],
      "gold_sql": "SELECT \n    a.segmentid AS segment_id,\n    a.name AS segment_name,\n    a.totalmembers AS total_profiles,\n    a.createdTime AS created_time,\n    a.updatedTime AS updated_time\nFROM dim_segment a\nJOIN hkg_br_segment_target ad ON a.segmentid = ad.segmentid\nJOIN dim_target d ON ad.targetId = d.targetId\nWHERE d.dataflowName = 'SMS Opt-In'\nORDER BY a.name",
      "gold_api": [
        "GET /data/core/ups/audiences?property=destinationId==<destination_id>&limit=5",
        "GET /data/foundation/flowservice/flows?property=inheritedAttributes.properties.isDestinationFlow==true&limit=5"
      ]
    }
